  "\\$\\$([\\s\\S]*?)\\$\\$": "<div class=\"math-block-tmp\">$1</div><script>(function(){var s=document.createElement('script');s.src='https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.js';s.onload=function(){var links=document.getElementsByClassName('math-block-tmp');for(var i=0;i<links.length;i++){var div=links[i];var latex=div.innerText;div.innerHTML='';div.className='katex-display';try{katex.render(latex, div, {displayMode:true});}catch(e){div.innerHTML='<span style=\"color:red\">Error: '+e.message+'</span>';}}};document.head.appendChild(s);})();</script>",
